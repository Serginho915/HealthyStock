PORT=4000
NODE_ENV=production

# Public frontend origins allowed to call the API.
# Use comma-separated values if you have several domains.
CORS_ORIGIN=https://yourdomain.com

# In Docker production this is overridden by docker-compose.prod.yml.
DATABASE_URL=postgres://healthystock:replace-with-db-password@postgres:5432/healthystock

OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
OPENROUTER_SITE_URL=https://yourdomain.com

JWT_SECRET=
REFRESH_TOKEN_SECRET=

# Leave empty for same host. Set to .yourdomain.com for subdomain sharing.
REFRESH_COOKIE_DOMAIN=
REFRESH_COOKIE_SAMESITE=lax
TRUST_PROXY=true

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="HealthyStock <newsletter@yourdomain.com>"
