# Copy to .env before running docker-compose.prod.yml.
# This file is read by Docker Compose for variable substitution.

POSTGRES_DB=healthystock
POSTGRES_USER=healthystock
POSTGRES_PASSWORD=replace-with-a-long-random-database-password

NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
